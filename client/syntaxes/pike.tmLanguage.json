{
	"$schema": "https://raw.githubusercontent.com/microsoft/vscode/HEAD/src/vs/workbench/services/textMate/common/TMScopeRegistry.ts",
	"name": "Pike",
	"scopeName": "source.pike",
	"fileTypes": ["pike", "pmod", "mmod"],
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#preprocessor" },
		{ "include": "#constants" },
		{ "include": "#declarations" },
		{ "include": "#types" },
		{ "include": "#keywords" },
		{ "include": "#numbers" },
		{ "include": "#scope-access" },
		{ "include": "#member-access" },
		{ "include": "#type-cast" },
		{ "include": "#operators" },
		{ "include": "#punctuation" },
		{ "include": "#identifiers" }
	],
	"repository": {

		"comments": {
			"patterns": [
				{
					"comment": "Autodoc comments /** ... */",
					"name": "comment.block.documentation.pike",
					"begin": "/\\*\\*(?!/)",
					"end": "\\*/",
					"patterns": [
						{ "include": "#autodoc-tags" }
					]
				},
				{
					"comment": "Block comments /* ... */",
					"name": "comment.block.pike",
					"begin": "/\\*",
					"end": "\\*/"
				},
				{
					"comment": "Line doc comments //!",
					"name": "comment.line.documentation.pike",
					"match": "//!.*$"
				},
				{
					"comment": "Line comments //",
					"name": "comment.line.double-slash.pike",
					"match": "//.*$"
				}
			]
		},

		"autodoc-tags": {
			"patterns": [
				{
					"comment": "Autodoc @param, @return, @decl, @note, @fixme, @deprecated, @throws, @seealso, @example, @members, @endclass, @ignore, @belongs, @class, @b, @i, @tt, @pre, @code, @endcode, @url, @ref",
					"name": "keyword.other.documentation.pike",
					"match": "@(param|return|decl|note|fixme|deprecated|throws|seealso|example|members|endclass|ignore|belongs|class|b|i|tt|pre|code|endcode|url|ref)\\b"
				}
			]
		},

		"strings": {
			"patterns": [
				{
					"comment": "Raw strings #\" ... \"",
					"name": "string.quoted.other.pike",
					"begin": "#\"",
					"end": "\""
				},
				{
					"comment": "Single-character literals 'c'",
					"name": "string.quoted.single.pike",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.pike",
							"match": "\\\\[nrt\\\\\"'?]|\\\\x[0-9a-fA-F]{2}|\\\\[0-7]{1,3}"
						}
					]
				},
				{
					"comment": "Double-quoted strings",
					"name": "string.quoted.double.pike",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.pike",
							"match": "\\\\[nrt\\\\\"']|\\\\x[0-9a-fA-F]{2}|\\\\[0-7]{1,3}"
						},
						{
							"name": "constant.character.escape.pike",
							"match": "\\\\."
						}
					]
				}
			]
		},

		"preprocessor": {
			"patterns": [
				{
					"comment": "Preprocessor directives — must be anchored to line start",
					"name": "keyword.control.directive.pike",
					"match": "^\\s*#\\s*(if|ifdef|ifndef|else|elif|endif|define|undef|include|string|error|warning|pike|charset|pragma|require|elifdef|elifndef|elseif)\\b"
				}
			]
		},

		"constants": {
			"patterns": [
				{
					"comment": "Built-in constants",
					"name": "constant.language.pike",
					"match": "\\b(this|this_program|this_object|__LINE__|__FILE__|__DATE__|__TIME__|__DIR__|__VERSION__|__MAJOR__|__MINOR__|__PIKE__|__REAL_VERSION__|__REAL_MAJOR__|__REAL_MINOR__|__BUILD__|__REAL_BUILD__|__AUTO_BIGNUM__|__COUNTER__|__NT__|__amigaos__)\\b"
				},
				{
					"comment": "Boolean and null-like constants",
					"name": "constant.language.pike",
					"match": "\\b(true|false|UNDEFINED|zero)\\b"
				}
			]
		},

		"types": {
			"patterns": [
				{
					"comment": "Primitive types",
					"name": "storage.type.pike",
					"match": "\\b(void|mixed|int|float|string|array|mapping|multiset|object|program|function|type|zero|auto)\\b"
				}
			]
		},

		"keywords": {
			"patterns": [
				{
					"comment": "Modifiers — visibility, storage, and qualifiers",
					"name": "storage.modifier.pike",
					"match": "\\b(private|protected|public|static|extern|inline|local|final|variant|optional|nomask|global)\\b"
				},
				{
					"comment": "Control flow keywords",
					"name": "keyword.control.pike",
					"match": "\\b(if|else|for|while|do|foreach|switch|case|default|break|continue|return|gauge)\\b"
				},
				{
					"comment": "Declaration keywords",
					"name": "keyword.declaration.pike",
					"match": "\\b(class|enum|typedef|inherit|import|constant)\\b"
				},
				{
					"comment": "Exception and misc keywords",
					"name": "keyword.other.pike",
					"match": "\\b(catch|sscanf|typeof|lambda|predef|bits)\\b"
				}
			]
		},

		"numbers": {
			"patterns": [
				{
					"comment": "Hex literals 0x..., octal 0o..., binary 0b...",
					"name": "constant.numeric.pike",
					"match": "\\b(0[xX][0-9a-fA-F]+|0[oO][0-7]+|0[bB][01]+)\\b"
				},
				{
					"comment": "Float literals — must come before integer to prevent leading digit being consumed",
					"name": "constant.numeric.float.pike",
					"match": "\\b[0-9][0-9_]*\\.[0-9_]*([eE][+-]?[0-9_]+)?|(?<!\\.)\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?|\\b[0-9][0-9_]*[eE][+-]?[0-9_]+"
				},
				{
					"comment": "Integer literals",
					"name": "constant.numeric.pike",
					"match": "\\b[0-9][0-9_]*\\b"
				}
			]
		},

		"operators": {
			"patterns": [
				{
					"comment": "Operators — multi-char alternatives must precede single-char to prevent partial matches (e.g. -> must beat -)",
					"name": "keyword.operator.pike",
					"match": "\\?->|->>|->\\?|<<=|>>=|[+\\-*/%]=|\\+\\+|--|&&|\\|\\||==|!=|<=|>=|<<|>>|\\.{3}|\\.\\.|::|->|[+\\-*/%]|[!<>&\\|^~=]"
				}
			]
		},

		"punctuation": {
			"patterns": [
				{
					"comment": "Punctuation",
					"name": "punctuation.pike",
					"match": "[(){}\\[\\],;?:]"
				}
			]
		},

		"declarations": {
			"patterns": [
				{
					"comment": "Function declaration with qualified/complex type: array(int) name(, mapping(string:int) name(, string* name(, int|string name(",
					"match": "(\\b(?:void|mixed|int|float|string|array|mapping|multiset|object|program|function|type|zero|auto)\\b(?:\\s*\\*|\\s*\\|\\s*\\b(?:void|mixed|int|float|string|array|mapping|multiset|object|program|function|type|zero|auto)\\b|\\s*\\((?:[^()]|\\([^)]*\\))*\\))*(?:\\s*\\*)?)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "storage.type.pike" },
						"2": { "name": "entity.name.function.pike" }
					}
				},
				{
					"comment": "Function declaration with simple type: type name(",
					"match": "\\b((?:void|mixed|int|float|string|array|mapping|multiset|object|program|function|type|zero|auto))\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "storage.type.pike" },
						"2": { "name": "entity.name.function.pike" }
					}
				},
				{
					"comment": "Class declaration: class Name",
					"match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.declaration.pike" },
						"2": { "name": "entity.name.type.class.pike" }
					}
				},
				{
					"comment": "Enum declaration: enum Name",
					"match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.declaration.pike" },
						"2": { "name": "entity.name.type.enum.pike" }
					}
				},
				{
					"comment": "Typedef declaration: typedef type Name",
					"match": "\\b(typedef)\\s+.+\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*;",
					"captures": {
						"1": { "name": "keyword.declaration.pike" },
						"2": { "name": "entity.name.type.typedef.pike" }
					}
				},
				{
					"comment": "Inherit declaration: inherit Name",
					"match": "\\b(inherit)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
					"captures": {
						"1": { "name": "keyword.declaration.pike" },
						"2": { "name": "entity.other.inherited-class.pike" }
					}
				},
				{
					"comment": "Import declaration: import Name",
					"match": "\\b(import)\\s+([a-zA-Z_][a-zA-Z0-9_.]*)",
					"captures": {
						"1": { "name": "keyword.declaration.pike" },
						"2": { "name": "entity.other.inherited-class.pike" }
					}
				}
			]
		},

		"scope-access": {
			"patterns": [
				{
					"comment": "Scope resolution access: identifier::identifier",
					"match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*(::)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "variable.other.scope.pike" },
						"2": { "name": "punctuation.accessor.scope.pike" },
						"3": { "name": "variable.other.member.pike" }
					}
				},
				{
					"comment": "Scope resolution with predef/this_program: ::identifier",
					"match": "(::)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "punctuation.accessor.scope.pike" },
						"2": { "name": "variable.other.member.pike" }
					}
				}
			]
		},

		"member-access": {
			"patterns": [
				{
					"comment": "Arrow member access: identifier->identifier",
					"match": "(?<=\\w)\\s*(->)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "punctuation.accessor.arrow.pike" },
						"2": { "name": "variable.other.property.pike" }
					}
				},
				{
					"comment": "Dot member access: identifier.identifier (scope/module path, not decimal numbers)",
					"match": "(?<=[a-zA-Z_\\]])\\s*(\\.)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "punctuation.accessor.dot.pike" },
						"2": { "name": "variable.other.property.pike" }
					}
				}
			]
		},

		"type-cast": {
			"patterns": [
				{
					"comment": "Type cast: (type) expression",
					"match": "\\(\\s*(void|mixed|int|float|string|array|mapping|multiset|object|program|function|type|zero|auto)\\s*\\)",
					"captures": {
						"1": { "name": "storage.type.pike" }
					}
				}
			]
		},

		"identifiers": {
			"patterns": [
				{
					"comment": "Annotations __attribute__ __deprecated__ __func__",
					"name": "support.function.pike",
					"match": "__\\w+"
				},
				{
					"comment": "Backtick identifiers `name`",
					"name": "entity.name.function.pike",
					"match": "`[^`]+`"
				},
				{
					"comment": "Function and constructor-style calls: identifier(",
					"name": "entity.name.function.call.pike",
					"match": "(?<![a-zA-Z0-9_])[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
				},
				{
					"comment": "Class-like identifiers: uppercase-leading names in type/reference positions",
					"name": "entity.name.type.class.pike",
					"match": "(?<![a-zA-Z0-9_])[A-Z][a-zA-Z0-9_]*"
				},
				{
					"comment": "Remaining identifiers — conservative catch-all (only where not preceded by a type keyword to avoid matching type references)",
					"name": "variable.other.pike",
					"match": "(?<![a-zA-Z0-9_])[a-zA-Z_][a-zA-Z0-9_]*"
				}
			]
		}
	}
}
