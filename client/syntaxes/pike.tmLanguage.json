{
	"$schema": "https://raw.githubusercontent.com/microsoft/vscode/HEAD/src/vs/workbench/services/textMate/common/TMScopeRegistry.ts",
	"name": "Pike",
	"scopeName": "source.pike",
	"fileTypes": ["pike", "pmod", "mmod"],
	"patterns": [

		{
			"comment": "Doc comments /* * ... */ must come before block comment /*",
			"name": "comment.block.documentation",
			"begin": "/\\*\\*(?!/)",
			"end": "\\*/"
		},
		{
			"comment": "Block comments /* ... */",
			"name": "comment.block",
			"begin": "/\\*",
			"end": "\\*/"
		},
		{
			"comment": "Line doc comments //!",
			"name": "comment.line.documentation",
			"match": "//!.*$"
		},
		{
			"comment": "Line comments //",
			"name": "comment.line.double-slash",
			"match": "//.*$"
		},

		{
			"comment": "Raw strings #\" ... \"",
			"name": "string.raw",
			"begin": "#\"",
			"end": "\""
		},
		{
			"comment": "Single-character literals 'c'",
			"name": "string.quoted.single",
			"begin": "'",
			"end": "'",
			"patterns": [
				{
					"name": "constant.character.escape",
					"match": "\\\\[nrt\\\\\"'?]|\\\\x[0-9a-fA-F]{2}|\\\\[0-7]{1,3}"
				}
			]
		},
		{
			"comment": "Double-quoted strings (escape sequences before end-quote)",
			"name": "string.quoted.double",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape",
					"match": "\\\\[nrt\\\\\"']|\\\\x[0-9a-fA-F]{2}|\\\\[0-7]{1,3}"
				},
				{
					"name": "constant.character.escape",
					"match": "\\\\."
				}
			]
		},


		{

			"comment": "Preprocessor directives #if #ifdef #else #endif #define #include #string #pike #charset #pragma #require",
			"name": "keyword.directive",

			"match": "#\\s*(if|ifdef|ifndef|else|elif|endif|define|undef|include|string|error|warning|pike|charset|pragma|require|elifdef|elifndef|elseif)\\b"
		},

		{
			"comment": "Built-in constants __LINE__ __FILE__ this this_program etc.",
			"name": "constant.builtin",

			"match": "\\b(this|this_program|this_object|__LINE__|__FILE__|__DATE__|__TIME__|__DIR__|__VERSION__|__MAJOR__|__MINOR__|__PIKE__|__REAL_VERSION__|__REAL_MAJOR__|__REAL_MINOR__|__BUILD__|__REAL_BUILD__|__AUTO_BIGNUM__|__COUNTER__|__NT__|__amigaos__)\\b"
		},

		{
			"comment": "Type keywords — before identifiers so 'int x;' colors 'int'",
			"name": "support.type.primitive",
			"match": "\\b(void|mixed|int|float|string|array|mapping|multiset|object|program|function|type|zero)\\b"
		},

		{
			"comment": "Modifiers — visibility, storage, and other qualifiers",
			"name": "storage.modifier",

			"match": "\\b(private|protected|public|static|extern|inline|local|final|variant|optional|nomask)\\b"
		},

		{
			"comment": "Control flow keywords",
			"name": "keyword.control",
			"match": "\\b(if|else|for|while|do|foreach|switch|case|default|break|continue|return)\\b"
		},

		{
			"comment": "Declaration keywords",
			"name": "keyword.declaration",
			"match": "\\b(class|enum|typedef|inherit|import|constant)\\b"
		},

		{

			"comment": "Other keywords — catch, gauge, sscanf, typeof, lambda, predef, bits, global, auto",
			"name": "keyword.other",

			"match": "\\b(catch|gauge|sscanf|typeof|lambda|predef|bits|global|auto)\\b"
		},

		{
			"comment": "Annotations __attribute__ __deprecated__ __func__",
			"name": "support.function",
			"match": "__\\w+"
		},

		{
			"comment": "Hex literals 0x..., octal 0o..., binary 0b..., integer, float with exponent",
			"name": "constant.numeric",
			"match": "\\b(0[xX][0-9a-fA-F]+|0[oO][0-7]+|0[bB][01]+|[0-9][0-9_]*[uUlL]*)\\b|\\b[0-9][0-9_]*\\.[0-9_]*([eE][+-]?[0-9_]+)?[fFlL]?|\\b\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?[fFlL]?|\\b[0-9][0-9_]*[eE][+-]?[0-9_]+[fFlL]?"
		},

		{
			"comment": "Operators — arithmetic, comparison, bitwise, logical, assignment, increment, range, arrow, scope",
			"name": "keyword.operator",

			"match": "\\?->|->>|->\\?|[+\\-*/%]=?|\\+\\+|--|&&|\\|\\||!|==|!=|<=|>=|<|>|&|\\||\\^|~|\\.\\.\\.|\\.\\.|::|->|<<|>>|<<=|>>="
		},

		{
			"comment": "Punctuation — brackets, delimiters, arrow colon",
			"name": "punctuation",
			"match": "[(){}\\[\\],;\\.@?:]"
		},

		{
			"comment": "Backtick identifiers `name`",
			"name": "variable.other.readwrite",
			"match": "`[^`]+`"
		},

		{
			"comment": "Regular identifiers — catch-all at bottom",
			"name": "variable",
			"match": "[a-zA-Z_][a-zA-Z0-9_]*"
		}

	]
}
