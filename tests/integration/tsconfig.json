{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "./dist",
    "declaration": false,
    "rootDir": ".",
    "ignoreDeprecations": "6.0",
    "types": ["node", "vscode", "mocha"]
  },
  "include": ["suite/**/*.ts", "run-tests.ts"]
}
