{
  "name": "pike-language-server",
  "displayName": "Pike Language Server",
  "description": "Language support for Pike — diagnostics, completion, go-to-definition, hover, references, rename, formatting, and more",
  "version": "0.3.4-beta",
  "publisher": "thesmuks",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "pike",
    "pike-language",
    "lsp",
    "language-server"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TheSmuks/pike-language-server.git"
  },
  "homepage": "https://github.com/TheSmuks/pike-language-server",
  "license": "MIT",
  "extensionKind": ["workspace"],
  "activationEvents": [
    "onLanguage:pike"
  ],
  "main": "./client/dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pike",
        "extensions": [
          ".pike",
          ".pmod",
          ".mmod"
        ],
        "aliases": [
          "Pike"
        ]
      }
    ],
    "configuration": {
      "title": "Pike Language Server",
      "properties": {
        "pike.languageServer.path": {
          "type": "string",
          "default": "pike",
          "description": "Path to the Pike binary. Must be Pike 8.0 or newer.",
          "scope": "machine"
        },
        "pike.languageServer.pikeFmtPath": {
          "type": "string",
          "default": "pike-fmt",
          "description": "Path to the pike-fmt formatter binary.",
          "scope": "machine"
        },
        "pike.languageServer.diagnosticMode": {
          "type": "string",
          "default": "realtime",
          "enum": ["realtime", "saveOnly", "off"],
          "enumDescriptions": [
            "Report diagnostics as you type (debounced)",
            "Report diagnostics only on save",
            "Disable diagnostics"
          ],
          "description": "Controls when diagnostics are reported.",
          "scope": "window"
        },
        "pike.languageServer.diagnosticDebounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce interval (ms) for realtime diagnostics.",
          "minimum": 100,
          "maximum": 5000,
          "scope": "window"
        },
        "pike.languageServer.maxNumberOfProblems": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of diagnostic problems reported per file.",
          "minimum": 1,
          "maximum": 1000,
          "scope": "window"
        }
      }
    }
  },
  "dependencies": {}
}
